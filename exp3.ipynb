      "source": [
        "def is_keyword(word, keywords):\n",
        "    return word.upper() in keywords\n",
        "keywords1 = {\"ORDER\", \"CANCEL\", \"TRACK\"}\n",
        "print(is_keyword(\"TRACK\", keywords1))  # True\n",
        "keywords2 = {\"ISSUE\", \"RETURN\", \"SEARCH\"}\n",
        "print(is_keyword(\"RETURN\", keywords2))  # True"
      ]
    }
